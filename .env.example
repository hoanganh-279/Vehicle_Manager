# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT CONFIGURATION - DUAL-MODE
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# ── POSTGRESQL (RENDER) ──
# Uncomment this line when deploying to Render
# Render will automatically set this variable
# DATABASE_URL=postgresql://user:password@host:5432/database

# ── SQL SERVER (LOCAL) ──
# Used when DATABASE_URL is not set
DB_SERVER=LAPTOP-3J6T1I18\SQLEXPRESS01
DB_DATABASE=ParkingManagement

# ═══════════════════════════════════════════════════════════════════════════
# FLASK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-this-in-production

# ═══════════════════════════════════════════════════════════════════════════
# MOMO PAYMENT GATEWAY
# ═══════════════════════════════════════════════════════════════════════════
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=your_partner_code
MOMO_ACCESS_KEY=your_access_key
MOMO_SECRET_KEY=your_secret_key

# ── CALLBACK URLs ──
# Local development
# MOMO_REDIRECT_URL=http://localhost:5000/payment/result
# MOMO_IPN_URL=http://localhost:5000/payment/result

# Production (Render)
MOMO_REDIRECT_URL=https://your-app-name.onrender.com/payment/result
MOMO_IPN_URL=https://your-app-name.onrender.com/payment/result

# ═══════════════════════════════════════════════════════════════════════════
# STRIPE PAYMENT (Optional)
# ═══════════════════════════════════════════════════════════════════════════
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (Flask-Mail)
# ═══════════════════════════════════════════════════════════════════════════
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ═══════════════════════════════════════════════════════════════════════════
# TIMEZONE & LOCALE
# ═══════════════════════════════════════════════════════════════════════════
TZ=Asia/Ho_Chi_Minh
LANG=vi_VN.UTF-8

# ═══════════════════════════════════════════════════════════════════════════
# GUNICORN CONFIGURATION (Production)
# ═══════════════════════════════════════════════════════════════════════════
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:5000

# ═══════════════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════════════
# 1. DATABASE_URL is automatically set by Render when you create a PostgreSQL database
# 2. If DATABASE_URL exists → PostgreSQL mode (Render)
# 3. If DATABASE_URL is not set → SQL Server mode (Local)
# 4. Never commit .env file to Git (already in .gitignore)
# 5. Update MOMO_REDIRECT_URL and MOMO_IPN_URL with your actual Render URL
